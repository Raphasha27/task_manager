# ==============================================================================
# Kirov Dynamics Standard gitignore
# ==============================================================================

# Python Compiled & Cache
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# Node.js / Web Assets
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-lock.yaml
.next/
out/
.docusaurus/
.cache/

# .NET / C#
bin/
obj/
*.user
*.userosscache
*.sln.docstates

# Java / Spring Boot
target/
*.class
*.jar
*.war
*.ear

# Environment Configs
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDEs & System files
.vscode/
.idea/
.DS_Store
Thumbs.db
*.log
*.pid
